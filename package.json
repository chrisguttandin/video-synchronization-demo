{
    "author": "Christoph Guttandin",
    "bugs": {
        "url": "https://github.com/chrisguttandin/video-synchronization-demo/issues"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "dependencies": {
        "timing-object": "^3.1.98",
        "timing-provider": "^7.2.10",
        "timingsrc": "^1.4.36"
    },
    "description": "A website to demo usage of the media-sync package with a TimingObject and a TimingProvider.",
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-angular": "^21.0.2",
        "autoprefixer": "^10.5.0",
        "babel-loader": "^10.1.1",
        "commitizen": "^4.3.2",
        "copy-webpack-plugin": "^14.0.0",
        "cssnano": "^8.0.2",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.39.4",
        "eslint-config-holy-grail": "^63.0.3",
        "globals": "^17.6.0",
        "html-minifier": "^4.0.0",
        "htmlhint": "^1.9.2",
        "husky": "^9.1.7",
        "hyperlink": "^5.0.4",
        "lint-staged": "^17.0.7",
        "postcss": "^8.5.15",
        "postcss-cli": "^11.0.1",
        "prettier": "^3.8.4",
        "rimraf": "^6.1.3",
        "stylelint": "^17.13.0",
        "stylelint-config-holy-grail": "^13.0.2",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3",
        "webpack-dev-server": "^5.2.5"
    },
    "homepage": "https://chrisguttandin.github.io/video-synchronization-demo",
    "license": "MIT",
    "main": "src/index.html",
    "name": "video-synchronization-demo",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/chrisguttandin/video-synchronization-demo.git"
    },
    "scripts": {
        "build": "rimraf build/* && html-minifier --config-file config/html-minifier/config.json --file-ext html --input-dir src --output-dir build && npx webpack --config config/webpack/production.js && npx postcss src/**/*.css --base src/ --config config/postcss/ --dir build/",
        "lint": "npm run lint:config && npm run lint:src",
        "lint:config": "eslint --config config/eslint/config.mjs --ext .cjs --ext .js --ext .mjs --report-unused-disable-directives config/",
        "lint:src": "eslint --config config/eslint/src.mjs --ext .js --report-unused-disable-directives src/ && htmlhint --config config/htmlhint/document.json 'src/**/index.html' && npx stylelint 'src/**/*.css' --config config/stylelint/config.json",
        "monitor": "npx webpack server --config config/webpack/development.js",
        "prepare": "husky",
        "test": "npm run lint"
    },
    "version": "2.0.50"
}
